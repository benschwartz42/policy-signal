# Copy to .env for local runs (run.py loads it automatically). In production
# these are GitHub Actions secrets, not a file.

# --- LLM scoring (required for live scoring; offline stub used if absent) ---
ANTHROPIC_API_KEY=

# --- Email transport: Resend primary, SMTP fallback ---
# If RESEND_API_KEY is set, Resend is used. Otherwise, if SMTP_HOST is set, SMTP.
RESEND_API_KEY=

# Google Workspace SMTP fallback (use an app password, not your login password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=digest@zdkinnovations.com
# SMTP_PASSWORD=

# --- Optional source keys ---
REGS_GOV_API_KEY=
COURTLISTENER_TOKEN=
